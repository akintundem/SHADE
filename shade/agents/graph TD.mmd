graph TD
  %% Entry and Orchestration
  U[User / Client] -->|"request"| O[MasterOrchestrator]
  O -->|"keyword + LLM hints"| R[RoutingNode]
  R -->|"routing_decision: single or multi-domain"| O

  %% Single vs Multi path
  O -->|"single-agent route"| A_event[EnhancedEventAgent]
  O -->|"multi-agent route"| AC[AgentCoxordinator]

  %% Coordinator patterns
  AC -->|"SEQUENTIAL pattern"| AG[Agents]
  AC -->|"PARALLEL pattern"| AG
  AC -->|"CONDITIONAL pattern"| AG
  AC -->|"REQUEST_RESPONSE pattern"| AG
  AC -->|"BROADCAST pattern"| AG

  %% Agents and internals
  subgraph Agents
    A_event --> T_event[Tools]
    A_event --> RAG_event[RAG System]

    A_budget[BudgetAgent] --> T_budget[Tools]
    A_venue[VenueAgent] --> T_venue[Tools]
    A_vendor[VendorAgent] --> T_vendor[Tools]
    A_risk[RiskAgent] --> T_risk[Tools]
    A_attendee[AttendeeAgent] --> T_attendee[Tools]
    A_weather[WeatherAgent] --> T_weather[Tools]
    A_comm[CommunicationAgent] --> T_comm[Tools]

    A_event -.uses.- CP_event[CommunicationProtocol]
    A_budget -.uses.- CP_budget[CommunicationProtocol]
    A_venue -.uses.- CP_venue[CommunicationProtocol]
    A_vendor -.uses.- CP_vendor[CommunicationProtocol]
    A_risk -.uses.- CP_risk[CommunicationProtocol]
    A_attendee -.uses.- CP_attendee[CommunicationProtocol]
    A_weather -.uses.- CP_weather[CommunicationProtocol]
    A_comm -.uses.- CP_comm[CommunicationProtocol]
  end

  %% Message bus
  subgraph Messaging
    MB[MessageBus]
  end

  CP_event --- MB
  CP_budget --- MB
  CP_venue --- MB
  CP_vendor --- MB
  CP_risk --- MB
  CP_attendee --- MB
  CP_weather --- MB
  CP_comm --- MB

  %% Orchestrator context/state
  O -. maintains .-> CH[Conversation Histories]
  O -. maintains .-> GC[Global Context]
  O -. owns .-> MB

  %% Notes
  classDef dim fill:#f7f7f7,stroke:#ddd,color:#444;
  class CH,GC dim