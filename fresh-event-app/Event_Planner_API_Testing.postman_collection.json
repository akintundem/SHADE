		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Generate unique test data for each run",
					"if (!pm.environment.get('test_event_id')) {",
					"    const timestamp = Date.now();",
					"    pm.environment.set('test_event_id', '');",
					"    pm.environment.set('test_event_name', 'Test Event ' + timestamp);",
					"    pm.environment.set('test_event_description', 'Test Description ' + timestamp);",
					"    pm.environment.set('test_event_location', 'Test Location ' + timestamp);",
					"    console.log('Generated test data for run:', timestamp);",
					"}"
				]
			}
		}
	],
