			"name": "🏥 Health Check",
			"item": [
				{
					"name": "API Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/health",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "health"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Health check should return 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response should contain status UP', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.status).to.eql('UP');",
									"});",
									"",
									"pm.test('Response should contain service name', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.service).to.eql('Event Planner API');",
									"});",
									"",
									"pm.test('Response should contain version', function () {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.version).to.eql('1.0.0');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
