# Environment Variables Template
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and will not be committed to version control

# ============================================
# REQUIRED SECRETS - MUST BE SET
# ============================================
# These values have no defaults and MUST be provided

# JWT Secret - Used for signing and verifying JWT tokens
# Must be at least 32 characters long
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-here-minimum-32-characters

# Internal Assistant Secret - Used for authentication between Java and Python services
# Generate a secure random string: openssl rand -base64 32
INTERNAL_ASSISTANT_SECRET=your-internal-assistant-secret-here

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=eventplanner
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# ============================================
# REDIS CONFIGURATION
# ============================================
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_TIMEOUT=2000ms
SPRING_REDIS_DATABASE=0
SPRING_REDIS_POOL_MAX_ACTIVE=8
SPRING_REDIS_POOL_MAX_IDLE=8
SPRING_REDIS_POOL_MIN_IDLE=0

# ============================================
# MONGODB CONFIGURATION
# ============================================
MONGODB_URL=mongodb://mongodb:27017/event_planner
MONGODB_INITDB=event_planner

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
AUTH_SESSION_MAX_CONCURRENT=5

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_MAX_SIZE=1000
CACHE_EXPIRE_AFTER_WRITE=300s

# ============================================
# OPENAI & AI CONFIGURATION
# ============================================
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.4
OPENAI_CHAT_MAX_TOKENS=1000
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ============================================
# PINECONE CONFIGURATION
# ============================================
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=local
PINECONE_PROJECT=local-project
PINECONE_INDEX=event-templates
PINECONE_VECTORSTORE_INDEX=event-templates
PINECONE_VECTORSTORE_NAMESPACE=event-planning

# ============================================
# FIREBASE CONFIGURATION
# ============================================
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=
FIREBASE_PROJECT_ID=

# ============================================
# EMAIL CONFIGURATION (RESEND)
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ============================================
# EXTERNAL API KEYS
# ============================================
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# ============================================
# APPLICATION CONFIGURATION
# ============================================
SPRING_PROFILES_ACTIVE=docker
APP_BASE_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
SHADE_ASSISTANT_URL=http://python-app:8000
WEATHER_BASE_URL=http://localhost:8089

# ============================================
# API DOCUMENTATION
# ============================================
SWAGGER_UI_PATH=/swagger-ui
API_DOCS_PATH=/v3/api-docs
API_TITLE=Event Planner API
API_DESCRIPTION=AI-powered event planning platform
API_VERSION=1.0.0

# ============================================
# LOGGING
# ============================================
LOG_PATTERN=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_WEB=INFO
LOG_LEVEL_AI=INFO
LOG_LEVEL_VALIDATION=WARN

# ============================================
# MANAGEMENT ENDPOINTS
# ============================================
MANAGEMENT_ENDPOINTS=health,info,metrics
MANAGEMENT_HEALTH_DETAILS=always
MANAGEMENT_ELASTICSEARCH_ENABLED=false
