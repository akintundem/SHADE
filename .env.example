# Environment variables
# Fill in required values before running the monolith.
# Leave empty values empty if you do not intend to enable the related feature.

# ============================================
# CORE APP
# ============================================
# Which Spring profile to run (e.g. dev, prod, docker).
SPRING_PROFILES_ACTIVE=
# Base URL of the monolith (used in outbound emails/links).
APP_BASE_URL=
# Secret used for ticket QR-code signatures.
APP_TICKET_QR_SECRET=

# ============================================
# DATABASE (POSTGRES — local, see scripts/setup-local.sh)
# ============================================
# Run scripts/setup-local.sh to create DB + enable PostGIS (required for geometry columns).
# host.docker.internal = host machine when Java app runs in Docker
DB_HOST=
DB_PORT=
DB_NAME=
# One-time schema creation when Flyway migrations are not yet applied:
# SPRING_JPA_HIBERNATE_DDL_AUTO=create
# After first successful startup, remove this or set to "validate".
# Homebrew Postgres: use your macOS username (or create user 'postgres'); often no password
DB_USERNAME=
DB_PASSWORD=
# Local Postgres: no SSL
DB_SSLMODE=

# ============================================
# REDIS
# ============================================
SPRING_REDIS_HOST=
SPRING_REDIS_PORT=
SPRING_REDIS_PASSWORD=
# Optional overrides (defaults in application.yml if omitted).
SPRING_REDIS_TIMEOUT=
SPRING_REDIS_DATABASE=
SPRING_REDIS_POOL_MAX_ACTIVE=
SPRING_REDIS_POOL_MAX_IDLE=
SPRING_REDIS_POOL_MIN_IDLE=

# ============================================
# EXTERNAL SERVICES
# ============================================
# Default email senders (used by the monolith when publishing email jobs).
EXTERNAL_EMAIL_FROM=
EXTERNAL_EMAIL_FROM_EVENTS=

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_URL=
RABBITMQ_EXCHANGE=
RABBITMQ_EMAIL_QUEUE=
RABBITMQ_EMAIL_ROUTING_KEY=
RABBITMQ_PUSH_QUEUE=
RABBITMQ_PUSH_ROUTING_KEY=
RABBITMQ_PREFETCH=
RABBITMQ_RECONNECT_MS=
RABBITMQ_REQUEUE_ON_ERROR=

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_API_KEY=
RESEND_FROM=
ALLOWED_TEMPLATES=
APP_ASSET_BUCKET=
LOGO_URL=

# ============================================
# PUSH SERVICE (FIREBASE)
# ============================================
# Path as seen inside push-service container: file must live under push-service/cred/
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=
FIREBASE_PROJECT_ID=

# ============================================
# SECURITY / AUTH (OIDC / Auth0)
# ============================================
# JWT validation (use Auth0 issuer, JWKS, audience).
OIDC_ISSUER_URI=
OIDC_JWK_SET_URI=
OIDC_AUDIENCE=
# Auth0 Management API (optional: profile sync, delete user, sign-out).
AUTH0_DOMAIN=
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
# Auto-provisioning of users from JWTs (true/false).
SECURITY_JWT_AUTO_PROVISION=
# RBAC policy location (e.g. classpath:rbac/RBAC_policy.yml).
RBAC_POLICY_LOCATION=

# Service-to-service auth (Kong X-API-Key).
SERVICE_AUTH_ENABLED=
SERVICE_AUTH_REQUIRE_HEADER=
SERVICE_API_KEY=
SERVICE_ROLE_ALLOWED_PATHS=

# ============================================
# OBJECT STORAGE (MinIO — S3-compatible, replaces AWS S3)
# ============================================
# MinIO uses same env vars as S3; use MinIO root user as access key.
# When set, cover and profile image URLs are built against this endpoint (images are pulled from MinIO).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Bucket names (minio-init creates these: shade-user-assets, shade-event-assets)
AWS_S3_USER_BUCKET=
AWS_S3_EVENT_BUCKET=
# MinIO runs natively on the host (Homebrew). Always use http://localhost:9000.
AWS_S3_ENDPOINT=http://localhost:9000
# Must be true for MinIO (path-style URLs)
AWS_S3_PATH_STYLE=

# ============================================
# MINIO (docker-compose — must match credentials above)
# ============================================
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ============================================
# FEEDS CLEANUP SCHEDULER
# ============================================
# Max age (minutes) for incomplete uploads.
FEEDS_CLEANUP_MAX_AGE_MINUTES=
# Cron schedule for cleanup job (spring cron format).
FEEDS_CLEANUP_CRON=


# ============================================
# KONG GATEWAY / API GATEWAY
# ============================================
# Service API key shared between Kong and Java app
GATEWAY_SERVICE_API_KEY=
# AI service shared secret for Kong
AI_GATEWAY_SHARED_SECRET=
# CORS allowed origins (comma-separated)
KONG_CORS_ORIGINS=

# ============================================
# AI SERVICE
# ============================================
# AI service secret (shared with Kong)
AI_SERVICE_SECRET=
EXTERNAL_AI_SERVICE_SECRET=
# OpenAI key (used by ai-service container).
OPENAI_API_KEY=
# OIDC settings for AI service (optional).
AI_OIDC_ISSUER=
AI_OIDC_AUDIENCE=
