# Event Planner Local Development Environment Variables
# Copy this file to .env and update the values as needed

# Database Configuration (using Docker service names)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=eventplanner
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis Configuration (using Docker service names)
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_DATABASE=0
SPRING_REDIS_TIMEOUT=2000ms
SPRING_REDIS_POOL_MAX_ACTIVE=8
SPRING_REDIS_POOL_MAX_IDLE=8
SPRING_REDIS_POOL_MIN_IDLE=0

# MongoDB Configuration (using Docker service names)
MONGODB_URL=mongodb://mongodb:27017/event_planner

# Database Pool Configuration
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_EXPIRE_AFTER_WRITE=3600s

# Logging Configuration
LOG_PATTERN=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
LOGGING_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_WEB=INFO
LOG_LEVEL_AI=INFO
LOG_LEVEL_VALIDATION=INFO

# Management Endpoints
MANAGEMENT_ENDPOINTS=health,info,metrics
MANAGEMENT_HEALTH_DETAILS=always
MANAGEMENT_ELASTICSEARCH_ENABLED=false

# Application Configuration
APP_CORS_ALLOWED_ORIGINS=*
SPRING_PROFILES_ACTIVE=docker

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_here_change_this_in_production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Session Configuration
AUTH_SESSION_MAX_CONCURRENT=5

# Internal Assistant Secret (CHANGE THIS IN PRODUCTION!)
INTERNAL_ASSISTANT_SECRET=your_internal_secret_here_change_this_in_production

# Python Assistant URL
SHADE_ASSISTANT_URL=http://python-app:8000

# External API Keys (REPLACE WITH REAL KEYS)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4
OPENAI_CHAT_TEMPERATURE=0.7
OPENAI_CHAT_MAX_TOKENS=2000
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_EMBEDDING_DIMENSIONS=1536

PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_PROJECT=your_pinecone_project
PINECONE_INDEX=event-planner-index
PINECONE_VECTORSTORE_INDEX=event-planner-vectors
PINECONE_VECTORSTORE_NAMESPACE=events

FIREBASE_SERVICE_ACCOUNT_KEY=your_firebase_service_account_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here

SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@eventplanner.com

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# API Documentation
SWAGGER_UI_PATH=/swagger-ui.html
API_DOCS_PATH=/v3/api-docs
API_TITLE=Event Planner API
API_DESCRIPTION=Comprehensive Event Planning API
API_VERSION=1.0.0
